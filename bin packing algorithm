#include <stdio.h>

#define MAX 50

int main() {
    int n, i, j;
    float bin[MAX], item[MAX], cap;

    printf("Enter number of items: ");
    scanf("%d", &n);

    if (n <= 0 || n > MAX) {
        printf("Invalid number of items.\n");
        return 1;
    }

    printf("Enter bin capacity: ");
    scanf("%f", &cap);

    // Input item sizes and initialize bins
    for (i = 0; i < n; i++) {
        printf("Enter size of item %d: ", i + 1);
        scanf("%f", &item[i]);
        bin[i] = cap;  // each bin starts full
    }

    // First Fit Algorithm
    for (i = 0; i < n; i++) {
        for (j = 0; j < n; j++) {
            if (bin[j] >= item[i]) {
                bin[j] -= item[i];
                printf("Item %d placed in Bin %d\n", i + 1, j + 1);
                break;
            }
        }
        if (j == n) {
            printf("Item %d cannot be placed in any bin\n", i + 1);
        }
    }

    // Output remaining space
    printf("\nRemaining space in bins:\n");
    for (i = 0; i < n; i++) {
        printf("Bin %d: %.2f\n", i + 1, bin[i]);
    }

    return 0;
}
