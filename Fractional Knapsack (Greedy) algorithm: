#include <stdio.h>

#define MAX 50

int main() {
    int n, i, j;
    float w[MAX], p[MAX], ratio[MAX];
    float temp, capacity, profit = 0;

    printf("Enter number of items: ");
    scanf("%d", &n);

    if (n <= 0 || n > MAX) {
        printf("Invalid number of items.\n");
        return 1;
    }

    // Input weights and profits
    for (i = 0; i < n; i++) {
        printf("Enter weight and profit of item %d: ", i + 1);
        scanf("%f %f", &w[i], &p[i]);

        if (w[i] == 0) {
            printf("Weight cannot be zero.\n");
            return 1;
        }

        ratio[i] = p[i] / w[i];
    }

    printf("Enter knapsack capacity: ");
    scanf("%f", &capacity);

    if (capacity < 0) {
        printf("Invalid capacity.\n");
        return 1;
    }

    // Sort items by profit/weight ratio (descending)
    for (i = 0; i < n - 1; i++) {
        for (j = i + 1; j < n; j++) {
            if (ratio[i] < ratio[j]) {
                // Swap ratio
                temp = ratio[i];
                ratio[i] = ratio[j];
                ratio[j] = temp;

                // Swap weights
                temp = w[i];
                w[i] = w[j];
                w[j] = temp;

                // Swap profits
                temp = p[i];
                p[i] = p[j];
                p[j] = temp;
            }
        }
    }

    // Apply greedy selection
    for (i = 0; i < n; i++) {
        if (w[i] <= capacity) {
            printf("Taking full item %d\n", i + 1);
            profit += p[i];
            capacity -= w[i];
        } else {
            printf("Taking fractional part of item %d\n", i + 1);
            profit += ratio[i] * capacity;
            break;
        }
    }

    printf("Maximum profit = %.2f\n", profit);

    return 0;
}
